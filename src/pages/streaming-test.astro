---
import Layout from "../layouts/Layout.astro";

Astro.response.headers.set("Cache-Control", "no-store, must-revalidate");
---

<Layout>
	<section
		style="
			padding: 3rem 1.5rem;
			font-family: system-ui, sans-serif;
			max-width: 720px;
			margin: auto;
		"
	>
		<p style="margin: 0 0 1.5rem; font-size: 0.9rem; color: #64748b;">
			<a href="/" style="color: #2563eb; text-decoration: none; font-weight: 600;">Home</a>
			<span style="margin: 0 0.5rem; color: #cbd5e1;">|</span>
			<span style="color: #334155;">Large Response Test</span>
		</p>

		<h1 style="font-size: 1.75rem; font-weight: 700; margin: 0 0 1rem; color: #0f172a; line-height: 1.3;">
			Transfer-Encoding: Chunked Streaming Test
		</h1>

		<p style="margin: 0 0 1.75rem; font-size: 1.05rem; line-height: 1.6; color: #334155; text-align: left;">
			This replicates the iODigital customer use case. Click a button below.
			<strong>If streaming works:</strong> text should appear word-by-word incrementally.
			<strong>If buffered (Launch issue):</strong> the full response appears all at once.
		</p>

		<div
			style="
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
				margin-bottom: 1.5rem;
			"
		>
			<button
				type="button"
				data-stream="fast"
				class="stream-btn"
				style="
					padding: 0.65rem 1.1rem;
					font-size: 0.95rem;
					font-weight: 600;
					border: none;
					border-radius: 8px;
					cursor: pointer;
					background: linear-gradient(83.21deg, #22c55e 0%, #15803d 100%);
					color: white;
					box-shadow: inset 0 0 0 1px rgba(255,255,255,0.12);
				"
			>
				Stream (Fast)
			</button>
			<button
				type="button"
				data-stream="medium"
				class="stream-btn"
				style="
					padding: 0.65rem 1.1rem;
					font-size: 0.95rem;
					font-weight: 600;
					border: none;
					border-radius: 8px;
					cursor: pointer;
					background: linear-gradient(83.21deg, #eab308 0%, #a16207 100%);
					color: white;
					box-shadow: inset 0 0 0 1px rgba(255,255,255,0.12);
				"
			>
				Stream (Medium)
			</button>
			<button
				type="button"
				data-stream="slow"
				class="stream-btn"
				style="
					padding: 0.65rem 1.1rem;
					font-size: 0.95rem;
					font-weight: 600;
					border: none;
					border-radius: 8px;
					cursor: pointer;
					background: linear-gradient(83.21deg, #ef4444 0%, #b91c1c 100%);
					color: white;
					box-shadow: inset 0 0 0 1px rgba(255,255,255,0.12);
				"
			>
				Stream (Slow)
			</button>
		</div>

		<div
			id="stream-output"
			style="
				min-height: 8rem;
				padding: 1.25rem;
				border-radius: 12px;
				background: #f8fafc;
				border: 1px solid #e2e8f0;
				color: #0f172a;
				font-size: 1rem;
				line-height: 1.65;
				text-align: left;
				white-space: pre-wrap;
				word-break: break-word;
			"
		>
		</div>

		<p style="margin-top: 2rem; text-align: center;">
			<a href="/" style="color: #fbbf24; text-decoration: none; font-weight: 600;">← Back to Home</a>
		</p>
	</section>
</Layout>

<script is:inline>
	(function () {
		var out = document.getElementById("stream-output");
		var buttons = document.querySelectorAll("[data-stream]");
		buttons.forEach(function (btn) {
			btn.addEventListener("click", async function () {
				var speed = btn.getAttribute("data-stream");
				if (!out) return;
				out.textContent = "";
				try {
					var res = await fetch("/api/stream-test?speed=" + encodeURIComponent(speed));
					if (!res.ok || !res.body) {
						out.textContent = "Request failed (" + res.status + ").";
						return;
					}
					var reader = res.body.getReader();
					var decoder = new TextDecoder();
					while (true) {
						var result = await reader.read();
						if (result.done) break;
						out.textContent += decoder.decode(result.value, { stream: true });
					}
					out.textContent += decoder.decode();
				} catch (e) {
					out.textContent = "Error: " + (e && e.message ? e.message : String(e));
				}
			});
		});
	})();
</script>
