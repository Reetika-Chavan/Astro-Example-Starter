---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<section
		style="
			padding: 3rem 2rem;
			font-family: system-ui, sans-serif;
			max-width: 600px;
			margin: auto;
			text-align: center;
		"
	>
		<h1 style="font-size: 2rem; margin-bottom: 0.5rem;">Test 2 (destination)</h1>
		<p style="color: #059669; margin-bottom: 2rem; font-weight: 500;">
			Redirect from Test 1 worked. You are on Test 2.
		</p>
		<a
			href="/test1"
			style="
				display: inline-block;
				padding: 12px 24px;
				background: #059669;
				color: white;
				text-decoration: none;
				border-radius: 10px;
				font-weight: bold;
			"
		>
			Back to Test 1
		</a>
	</section>
</Layout>
